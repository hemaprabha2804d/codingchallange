int uniquePathsWithObstacles(int** obstacleGrid, int obstacleGridSize, int* obstacleGridColSize) {
    int m = obstacleGridSize;
    int n = obstacleGridColSize[0];

    // If the starting point or ending point has an obstacle, no paths are possible
    if (obstacleGrid[0][0] == 1 || obstacleGrid[m - 1][n - 1] == 1) {
        return 0;
    }

    // Use long long to prevent overflow during intermediate steps, 
    // though the final answer fits in int.
    long long dp[n];
    for (int i = 0; i < n; i++) dp[i] = 0;

    // Base case: Starting point
    dp[0] = 1;

    for (int i = 0; i < m; i++) {
        for (int j = 0; j < n; j++) {
            if (obstacleGrid[i][j] == 1) {
                // Obstacle found, reset paths to this cell to 0
                dp[j] = 0;
            } else if (j > 0) {
                // Ways to reach = Ways from above (existing dp[j]) + Ways from left (dp[j-1])
                dp[j] += dp[j - 1];
            }
        }
    }

    return (int)dp[n - 1];
}
